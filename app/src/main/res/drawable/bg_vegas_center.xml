<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <layer-list>
            <item android:top="8dp">
                <shape android:shape="rectangle">
                    <solid android:color="#FFB000"/> <corners android:radius="24dp"/>
                </shape>
            </item>
            <item android:bottom="4dp" android:top="12dp" android:left="4dp" android:right="4dp">
                <shape android:shape="rectangle">
                    <gradient android:startColor="#332200" android:endColor="#1A1100" android:angle="90"/>
                    <corners android:radius="20dp"/>
                    <stroke android:width="2dp" android:color="#FFD700"/>
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item android:top="8dp">
                <shape android:shape="rectangle">
                    <solid android:color="#0F0F0D"/>
                    <corners android:radius="24dp"/>
                </shape>
            </item>

            <item android:bottom="10dp">
                <shape android:shape="rectangle">
                    <gradient android:startColor="#4A4A40" android:endColor="#2A2A25" android:angle="270"/>
                    <corners android:radius="24dp"/>
                    <stroke android:width="1dp" android:color="#000000"/>
                </shape>
            </item>

            <item android:bottom="14dp" android:top="4dp" android:left="4dp" android:right="4dp">
                <shape android:shape="rectangle">
                    <gradient android:startColor="#2A2A25" android:endColor="#3A3A32" android:angle="90"/>
                    <corners android:radius="20dp"/>
                    <stroke android:width="2dp" android:color="#8B5A2B"/> </shape>
            </item>

            <item android:bottom="18dp" android:top="6dp" android:left="8dp" android:right="8dp">
                <shape android:shape="rectangle">
                    <solid android:color="#1AFFFFFF"/> <corners android:radius="18dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>