<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <layer-list>
            <item android:top="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="#00E5FF"/> <corners android:radius="16dp"/>
                </shape>
            </item>
            <item android:bottom="2dp" android:top="6dp" android:left="2dp" android:right="2dp">
                <shape android:shape="rectangle">
                    <gradient android:startColor="#003333" android:endColor="#001A1A" android:angle="90"/>
                    <corners android:radius="14dp"/>
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item android:top="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="#111111"/>
                    <corners android:radius="16dp"/>
                </shape>
            </item>
            <item android:bottom="6dp">
                <shape android:shape="rectangle">
                    <gradient android:startColor="#3B3B3B" android:endColor="#222222" android:angle="270"/>
                    <corners android:radius="16dp"/>
                    <stroke android:width="1dp" android:color="#000000"/>
                </shape>
            </item>
            <item android:bottom="8dp" android:top="2dp" android:left="2dp" android:right="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#2B2B2B"/>
                    <corners android:radius="14dp"/>
                    <stroke android:width="1dp" android:color="#444444"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>